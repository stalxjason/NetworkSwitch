<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- 当前网络模式卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前网络模式"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_current_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tv_mode_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检测中..."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Shizuku 状态卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shizuku 授权"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_shizuku_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检测中..."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_shizuku_auth"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="授权 Shizuku"
                    android:textSize="14sp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    app:cornerRadius="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Shizuku 通过 ADB 提供系统级权限，无需 Root 即可切换网络模式"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Root 状态 -->
        <TextView
            android:id="@+id/tv_root_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检测中..."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- 切换按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="切换 4G/5G"
            android:textSize="16sp"
            app:cornerRadius="12dp" />

        <!-- 打开系统设置 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="打开系统网络设置"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginTop="12dp"
            app:cornerRadius="12dp" />

        <!-- 刷新 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_refresh"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="刷新状态"
            android:textSize="13sp"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_marginTop="8dp" />

        <!-- Widget 提示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 长按桌面 → 添加小组件 → 找到「网络切换」即可添加桌面快捷开关"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</ScrollView>
